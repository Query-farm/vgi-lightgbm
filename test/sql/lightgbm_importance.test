# name: test/sql/lightgbm_importance.test
# description: feature_importance + SHAP explain (LightGBM-specific extras)
# group: [vgi_lightgbm]

require-env VGI_LIGHTGBM_WORKER

require vgi

require httpfs

statement ok
ATTACH 'lightgbm' AS lightgbm (TYPE vgi, LOCATION '${VGI_LIGHTGBM_WORKER}');

statement ok
CREATE TEMP VIEW diab_x AS
  SELECT sample_id, age, sex, bmi, bp, s1, s2, s3, s4, s5, s6 FROM lightgbm.diabetes();

# train a regression model to interpret
statement ok
SELECT * FROM lightgbm.fit((SELECT * FROM lightgbm.diabetes()), model_name => 'diab_imp',
                           estimator => 'lgbm_regressor', target => 'target', id => 'sample_id');

# ---- feature_importance: one ranked row per feature ----

query II
SELECT count(*), max(rank) FROM lightgbm.feature_importance('diab_imp', importance_type => 'gain');
----
10	10

# the top-ranked feature has the largest importance
query I
SELECT importance = max(importance) OVER () FROM lightgbm.feature_importance('diab_imp') WHERE rank = 1;
----
true

# split importance is also available
query I
SELECT count(*) FROM lightgbm.feature_importance('diab_imp', importance_type => 'split');
----
10

# ---- explain: long format, one row per (row, feature) ----

query I
SELECT count(*) FROM (DESCRIBE
  SELECT * FROM lightgbm.explain((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id'));
----
4

# 442 rows x 10 features
query I
SELECT count(*) FROM lightgbm.explain((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id');
----
4420

# SHAP additivity: base_value + sum(contributions) == the model's prediction (per row)
query I
WITH e AS (
  SELECT sample_id, any_value(base_value) AS base, sum(shap_value) AS s
  FROM lightgbm.explain((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id')
  GROUP BY sample_id),
p AS (
  SELECT sample_id, prediction
  FROM lightgbm.predict((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id'))
SELECT bool_and(abs(e.base + e.s - p.prediction) < 1.0)
FROM e JOIN p USING (sample_id);
----
true

# ---- explain on a multiclass model adds a 'class' column (one row per row x class x feature) ----

statement ok
SELECT * FROM lightgbm.fit(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm, target FROM lightgbm.iris()),
  model_name => 'iris_multi', estimator => 'lgbm_classifier', target => 'target', id => 'sample_id');

query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM lightgbm.explain(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm FROM lightgbm.iris()),
  model_name => 'iris_multi', id => 'sample_id'));
----
5

# 150 rows x 3 classes x 4 features
query I
SELECT count(*) FROM lightgbm.explain(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm FROM lightgbm.iris()),
  model_name => 'iris_multi', id => 'sample_id');
----
1800

statement ok
SELECT * FROM lightgbm.drop_model('diab_imp');

statement ok
SELECT * FROM lightgbm.drop_model('iris_multi');

statement ok
DETACH lightgbm;
