# name: test/sql/lightgbm_importance.test
# description: feature_importance + SHAP explain (LightGBM-specific extras)
# group: [vgi_lightgbm]

require-env VGI_LIGHTGBM_WORKER

require vgi

require httpfs

statement ok
ATTACH 'lightgbm' AS lightgbm (TYPE vgi, LOCATION '${VGI_LIGHTGBM_WORKER}');

statement ok
CREATE TEMP VIEW diab_x AS
  SELECT sample_id, age, sex, bmi, bp, s1, s2, s3, s4, s5, s6 FROM lightgbm.diabetes();

# train a regression model to interpret
statement ok
SELECT * FROM lightgbm.fit((SELECT * FROM lightgbm.diabetes()), model_name => 'diab_imp',
                           estimator => 'lgbm_regressor', target => 'target', id => 'sample_id');

# ---- feature_importance: one ranked row per feature ----

query II
SELECT count(*), max(rank) FROM lightgbm.feature_importance('diab_imp', importance_type => 'gain');
----
10	10

# the top-ranked feature has the largest importance
query I
SELECT importance = max(importance) OVER () FROM lightgbm.feature_importance('diab_imp') WHERE rank = 1;
----
true

# split importance is also available
query I
SELECT count(*) FROM lightgbm.feature_importance('diab_imp', importance_type => 'split');
----
10

# ---- explain: long format, one row per (row, feature) ----

query I
SELECT count(*) FROM (DESCRIBE
  SELECT * FROM lightgbm.explain((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id'));
----
4

# 442 rows x 10 features
query I
SELECT count(*) FROM lightgbm.explain((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id');
----
4420

# SHAP additivity: base_value + sum(contributions) == the model's prediction (per row)
query I
WITH e AS (
  SELECT sample_id, any_value(base_value) AS base, sum(shap_value) AS s
  FROM lightgbm.explain((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id')
  GROUP BY sample_id),
p AS (
  SELECT sample_id, prediction
  FROM lightgbm.predict((SELECT * FROM diab_x), model_name => 'diab_imp', id => 'sample_id'))
SELECT bool_and(abs(e.base + e.s - p.prediction) < 1.0)
FROM e JOIN p USING (sample_id);
----
true

# ---- explain on a multiclass model adds a 'class' column (one row per row x class x feature) ----

statement ok
SELECT * FROM lightgbm.fit(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm, target FROM lightgbm.iris()),
  model_name => 'iris_multi', estimator => 'lgbm_classifier', target => 'target', id => 'sample_id');

query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM lightgbm.explain(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm FROM lightgbm.iris()),
  model_name => 'iris_multi', id => 'sample_id'));
----
5

# 150 rows x 3 classes x 4 features
query I
SELECT count(*) FROM lightgbm.explain(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm FROM lightgbm.iris()),
  model_name => 'iris_multi', id => 'sample_id');
----
1800

# ---- permutation_importance: ranked, one row per feature ----

query II
SELECT count(*), max(rank) FROM lightgbm.permutation_importance((SELECT * FROM lightgbm.diabetes()),
  model_name => 'diab_imp', target => 'target', n_repeats => 3);
----
10	10

# rank is consistent with importance_mean (rank 1 has the largest mean)
query I
SELECT importance_mean = max(importance_mean) OVER () FROM lightgbm.permutation_importance(
  (SELECT * FROM lightgbm.diabetes()), model_name => 'diab_imp', target => 'target', n_repeats => 3)
WHERE rank = 1;
----
true

# rank ascending <-> importance descending (no inversions)
query I
WITH p AS (
  SELECT importance_mean, rank FROM lightgbm.permutation_importance((SELECT * FROM lightgbm.diabetes()),
    model_name => 'diab_imp', target => 'target', n_repeats => 3))
SELECT count(*) = 0 FROM p a JOIN p b ON a.importance_mean > b.importance_mean WHERE a.rank > b.rank;
----
true

# ---- partial_dependence: a curve over a numeric feature ----

# grid_resolution points, NULL class for the binary/regression curve
query I
SELECT count(*) = 10 AND count(class) = 0 FROM lightgbm.partial_dependence(
  (SELECT * FROM lightgbm.diabetes()), model_name => 'diab_imp', feature => 'bmi', grid_resolution => 10);
----
true

# the grid spans the observed feature range
query I
WITH pd AS (
  SELECT min(feature_value) AS lo, max(feature_value) AS hi FROM lightgbm.partial_dependence(
    (SELECT * FROM lightgbm.diabetes()), model_name => 'diab_imp', feature => 'bmi', grid_resolution => 20)),
d AS (SELECT min(bmi) AS lo, max(bmi) AS hi FROM lightgbm.diabetes())
SELECT pd.lo >= d.lo - 1e-6 AND pd.hi <= d.hi + 1e-6 FROM pd, d;
----
true

# multiclass model -> one curve per class
query I
SELECT count(DISTINCT class) = 3 FROM lightgbm.partial_dependence(
  (SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm FROM lightgbm.iris()),
  model_name => 'iris_multi', feature => 'petal_length_cm', grid_resolution => 8);
----
true

# a non-existent feature errors clearly
statement error
SELECT * FROM lightgbm.partial_dependence(
  (SELECT sample_id, sepal_length_cm FROM lightgbm.iris()),
  model_name => 'iris_multi', feature => 'not_a_feature');
----

# a categorical (string) feature is rejected: PD supports numeric features only
statement ok
CREATE TEMP TABLE catdata AS
  SELECT i AS id, (i % 5)::DOUBLE AS x,
         CASE WHEN i % 2 = 0 THEN 'red' ELSE 'blue' END AS color,
         (CASE WHEN i % 2 = 0 THEN 1 ELSE 0 END) AS target
  FROM range(120) t(i);

statement ok
SELECT * FROM lightgbm.fit((SELECT id, x, color, target FROM catdata),
  model_name => 'cat_pd', target => 'target', id => 'id');

statement error
SELECT * FROM lightgbm.partial_dependence((SELECT id, x, color FROM catdata),
  model_name => 'cat_pd', feature => 'color');
----

statement ok
SELECT * FROM lightgbm.drop_model('cat_pd');

statement ok
SELECT * FROM lightgbm.drop_model('diab_imp');

statement ok
SELECT * FROM lightgbm.drop_model('iris_multi');

statement ok
DETACH lightgbm;
